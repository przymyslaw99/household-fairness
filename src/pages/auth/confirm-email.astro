---
import Layout from "@/layouts/Layout.astro";
import AuthMessageCard from "@/components/auth/AuthMessageCard.astro";
import { appendRedirectTarget, sanitizeLocalRedirectTarget } from "@/lib/auth/redirects";

const isAutoConfirmed = import.meta.env.DEV;
const redirectTarget = sanitizeLocalRedirectTarget(Astro.url.searchParams.get("redirectTo"));
const signInHref = appendRedirectTarget("/auth/signin", redirectTarget);

const content = isAutoConfirmed
  ? {
      emoji: "✅",
      heading: "Registration successful",
      description: "Your account has been created. You can now sign in.",
      linkText: "Go to sign in",
    }
  : {
      emoji: "📧",
      heading: "Check your email",
      description: "We've sent a confirmation link to your email address. Click it to activate your account.",
      linkText: "Back to sign in",
    };
---

<Layout title={content.heading}>
  <div class="bg-cosmic flex min-h-screen items-center justify-center p-4">
    <AuthMessageCard
      emoji={content.emoji}
      heading={content.heading}
      description={content.description}
      href={signInHref}
      linkText={content.linkText}
    />
  </div>
</Layout>
