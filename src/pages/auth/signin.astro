---
import AuthCard from "@/components/auth/AuthCard.astro";
import AuthFooterPrompt from "@/components/auth/AuthFooterPrompt.astro";
import SignInForm from "@/components/auth/SignInForm";
import Layout from "@/layouts/Layout.astro";

const error = Astro.url.searchParams.get("error");
---

<Layout title="Sign in">
  <AuthCard title="Sign in">
    <SignInForm serverError={error} client:load />
    <Fragment slot="footer">
      <AuthFooterPrompt prompt="Don't have an account?" href="/auth/signup" linkText="Sign up" />
    </Fragment>
  </AuthCard>
</Layout>
