---
import AuthCard from "@/components/auth/AuthCard.astro";
import Topbar from "@/components/Topbar.astro";
import InviteControls from "@/components/household/InviteControls";
import { requireCurrentHouseholdMember } from "@/lib/household/guards";
import { getActiveInviteForHousehold } from "@/lib/household/repository";
import { HOUSEHOLD_ROLES } from "@/lib/household/types";
import { createClient } from "@/lib/supabase";
import Layout from "@/layouts/Layout.astro";

const DASHBOARD_ROUTE = "/dashboard";

function getInviteNotice(value: string | null): string | null {
  if (value === "ready") {
    return "Your active invite link is ready to share.";
  }

  if (value === "disabled") {
    return "The active invite link has been disabled.";
  }

  return null;
}

const supabase = createClient(Astro.request.headers, Astro.cookies);
const notice = getInviteNotice(Astro.url.searchParams.get("notice"));
const serverError = Astro.url.searchParams.get("error");

let activeInviteUrl: string | null = null;
let pageError = serverError;
let forbidden = false;

if (!supabase) {
  pageError ??= "Supabase is not configured.";
} else {
  const guard = await requireCurrentHouseholdMember(supabase, {
    requiredRoles: [HOUSEHOLD_ROLES.owner],
  });

  if (guard.status === "wrong_role") {
    forbidden = true;
  } else if (guard.status === "error") {
    pageError ??= "We could not load your invite settings right now.";
  } else if (guard.status === "allowed") {
    const activeInvite = await getActiveInviteForHousehold(supabase, guard.member.household_id);

    if (activeInvite.error) {
      pageError ??= "We could not load your active invite link right now.";
    } else if (activeInvite.data) {
      activeInviteUrl = new URL(`/join/${activeInvite.data.token}`, Astro.url.origin).toString();
    }
  }
}
---

<Layout title="Manage invite link">
  <div class="bg-cosmic min-h-screen p-4 sm:p-8">
    <div class="flex min-h-[calc(100vh-2rem)] flex-col sm:min-h-[calc(100vh-4rem)]">
      <Topbar />
      <div class="mx-auto flex w-full max-w-5xl flex-1 items-center justify-center py-6">
        <AuthCard title="Invite another household member" class="w-full max-w-3xl">
          {
            forbidden ? (
              <>
                <p class="mb-4 text-center text-sm text-blue-100/70">
                  Only the household owner can manage invite links.
                </p>
                <div class="flex justify-center">
                  <a
                    href={DASHBOARD_ROUTE}
                    class="inline-flex items-center justify-center rounded-md border border-white/10 bg-white/10 px-4 py-2 text-sm font-medium text-white transition hover:bg-white/20"
                  >
                    Return to dashboard
                  </a>
                </div>
              </>
            ) : (
              <>
                <p class="mb-6 text-center text-sm text-blue-100/70">
                  Create an invite link, share it, and disable it to stop new joins.
                </p>
                <InviteControls activeInviteUrl={activeInviteUrl} notice={notice} serverError={pageError} client:load />
              </>
            )
          }
        </AuthCard>
      </div>
    </div>
  </div>
</Layout>
